{
  "manifest_version": 3,
  "name": "QNA AutoZone / O'Reilly Vehicle Auto-Switcher",
  "version": "1.0.0",
  "description": "When opened from QNA Noor Auto Repair's Lookup page, auto-fills the VIN (or license plate) into AutoZone Pro and O'Reilly First Call's Add Vehicle dialog so every parts search in that tab is scoped to the right vehicle.",
  "content_scripts": [
    {
      "matches": [
        "https://www.autozonepro.com/*",
        "https://autozonepro.com/*",
        "https://www.firstcallonline.com/*",
        "https://firstcallonline.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [],
  "host_permissions": [
    "https://www.autozonepro.com/*",
    "https://autozonepro.com/*",
    "https://www.firstcallonline.com/*",
    "https://firstcallonline.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
